# -----------------------------------------------------------------------------
# R-Revenue Intelligence - Environment Variables Template
# -----------------------------------------------------------------------------
# This file is a template. DO NOT commit actual secrets to version control.
# Copy this file to '.env' and populate the values for local development.
# 
# For team-wide secrets management, we use Doppler.
# Run `doppler run -- docker compose up` to automatically inject secrets.
# -----------------------------------------------------------------------------

# --- Database (PostgreSQL with pgvector) ---
DB_USER=postgres
DB_PASSWORD=postgres
# DATABASE_URL is constructed in docker-compose.yml by default, but you can override:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/revenue_intel

# --- Cache and Queue (Redis) ---
# REDIS_URL is constructed in docker-compose.yml by default, but you can override:
# REDIS_URL=redis://localhost:6379

# --- Search (Meilisearch) ---
MEILI_MASTER_KEY=local_development_master_key

# --- AI & Transcription Services (Managed via Doppler preferably) ---
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# --- External CRM/Integrations (Managed via Doppler preferably) ---
HUBSPOT_ACCESS_TOKEN=your_hubspot_token_here
SALESFORCE_CLIENT_ID=your_salesforce_client_id_here
SENDGRID_API_KEY=your_sendgrid_api_key_here

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:3001
